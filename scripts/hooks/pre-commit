#!/bin/bash
# Git pre-commit hook for DevCodex
# Enforces code quality, formatting, build validation, tests, and commit message format
# This file is automatically installed by MSBuild during 'dotnet restore'

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}\n"

# 1. Check commit message format
echo "вҶ’ Validating commit message format..."
COMMIT_MSG_FILE="${1:-.git/COMMIT_EDITMSG}"
if [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" | head -1)
  
  # Valid gitmojis: рҹҡ§ вҡЎпёҸ рҹҗӣ вңЁ рҹ“қ вң… рҹ”’пёҸ вҷ»пёҸ вңҸпёҸ (plus Merge/Revert)
  if ! echo "$COMMIT_MSG" | grep -qE '^(рҹҡ§|вҡЎпёҸ|рҹҗӣ|вңЁ|рҹ“қ|вң…|рҹ”’пёҸ|вҷ»пёҸ|вңҸпёҸ)\s.{1,50}$|^Merge |^Revert '; then
    echo -e "${RED}вң— Commit message does not follow gitmoji format${NC}"
    echo "  Format: <gitmoji> <imperative-message> (max 50 chars after emoji)"
    echo "  Valid gitmojis:"
    echo "    рҹҡ§ Work in progress"
    echo "    вҡЎпёҸ Improve performance"
    echo "    рҹҗӣ Fix a bug"
    echo "    вңЁ Introduce new feature"
    echo "    рҹ“қ Add or update documentation"
    echo "    вң… Add, update, or pass tests"
    echo "    рҹ”’пёҸ Fix security issues"
    echo "    вҷ»пёҸ Refactor code"
    echo "    вңҸпёҸ Update file content"
    echo "  Example: вңЁ Added pre-commit hook system"
    exit 1
  fi
  
  # Check 50-character summary limit (after emoji and space)
  SUMMARY=$(echo "$COMMIT_MSG" | cut -d' ' -f2-)
  SUMMARY_LEN=${#SUMMARY}
  if [ $SUMMARY_LEN -gt 50 ]; then
    echo -e "${RED}вң— Commit summary exceeds 50 characters${NC}"
    echo "  Current: $SUMMARY_LEN chars"
    echo "  Message: $SUMMARY"
    exit 1
  fi
fi
echo -e "${GREEN}вң“ Commit message format valid${NC}\n"

# 2. Check and auto-fix code formatting
echo "вҶ’ Checking code formatting with dotnet format..."
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" = "github-pages-master" ]; then
  echo -e "${YELLOW}вҠҳ Skipping format check on github-pages-master branch${NC}\n"
else
  cd "$REPO_ROOT"
  if ! dotnet format --verify-no-changes --verbosity quiet 2>/dev/null; then
    echo -e "${YELLOW}вҡ  Code formatting issues detected - auto-fixing...${NC}"
    dotnet format --verbosity quiet
    echo -e "${YELLOW}вҶ’ Staging formatted changes...${NC}"
    git add -u
    echo -e "${GREEN}вң“ Code auto-formatted and staged${NC}\n"
  else
    echo -e "${GREEN}вң“ Code formatting valid${NC}\n"
  fi
fi

# 3. Build validation
echo "вҶ’ Validating build..."
if ! dotnet build -c Debug --no-restore > /dev/null 2>&1; then
  echo -e "${RED}вң— Build failed${NC}"
  echo "  Run: dotnet build"
  exit 1
fi
echo -e "${GREEN}вң“ Build successful${NC}\n"

# 4. Run tests
# echo "вҶ’ Running tests..."
# if ! dotnet test --no-build --logger "console;verbosity=minimal" 2>/dev/null; then
#   echo -e "${RED}вң— Tests failed${NC}"
#   exit 1
# fi
# echo -e "${GREEN}вң“ All tests passed${NC}\n"

echo -e "${GREEN}вң“ All pre-commit checks passed!${NC}\n"
exit 0
